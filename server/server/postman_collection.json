{
  "info": {
    "name": "SupportGPT API Collection",
    "description": "Postman Collection for SupportGPT Customer Support RAG Assistant Backend. Configure global collection variables `baseUrl` (e.g. `http://localhost:5001/api`) and `token` (your authenticated JWT Bearer token).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Operator",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"securepass123\",\n  \"role\": \"user\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["register"]
            }
          }
        },
        {
          "name": "Login Operator",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"securepass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/profile",
              "host": ["{{baseUrl}}"],
              "path": ["profile"]
            }
          }
        },
        {
          "name": "Update Profile Info",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane.smith@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/profile",
              "host": ["{{baseUrl}}"],
              "path": ["profile"]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"securepass123\",\n  \"newPassword\": \"newsecurepass456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/profile/password",
              "host": ["{{baseUrl}}"],
              "path": ["profile", "password"]
            }
          }
        },
        {
          "name": "Upload Avatar Picture",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "avatar",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/profile/avatar",
              "host": ["{{baseUrl}}"],
              "path": ["profile", "avatar"]
            }
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/documents/upload",
              "host": ["{{baseUrl}}"],
              "path": ["documents", "upload"]
            }
          }
        },
        {
          "name": "List User Documents",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/documents",
              "host": ["{{baseUrl}}"],
              "path": ["documents"]
            }
          }
        },
        {
          "name": "Delete Document",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/documents/:id",
              "host": ["{{baseUrl}}"],
              "path": ["documents", ":id"],
              "variable": [
                { "key": "id", "value": "your_document_id_here" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Knowledge Base & ChromaDB",
      "item": [
        {
          "name": "Get Knowledge Info Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/knowledge",
              "host": ["{{baseUrl}}"],
              "path": ["knowledge"]
            }
          }
        },
        {
          "name": "Trigger Re-index Compilations",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/knowledge/reindex",
              "host": ["{{baseUrl}}"],
              "path": ["knowledge", "reindex"]
            }
          }
        }
      ]
    },
    {
      "name": "AI Conversational Chat",
      "item": [
        {
          "name": "RAG Inquiry Completion",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"What is the return window?\",\n  \"modelName\": \"gpt-4o-mini\",\n  \"temperature\": 0.0,\n  \"sessionId\": \"SESS-postman-test-123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat",
              "host": ["{{baseUrl}}"],
              "path": ["chat"]
            }
          }
        },
        {
          "name": "Get Session History Threads",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/chat/history",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "history"]
            }
          }
        },
        {
          "name": "Clear Global Chat History",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/chat/history",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "history"]
            }
          }
        },
        {
          "name": "Delete Specific Session History",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/chat/history/:sessionId",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "history", ":sessionId"],
              "variable": [
                { "key": "sessionId", "value": "SESS-postman-test-123" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Management Controls",
      "item": [
        {
          "name": "Get Global System Metrics",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/stats",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "stats"]
            }
          }
        },
        {
          "name": "Query Cross-User Document Catalog",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/documents?search=",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "documents"],
              "query": [
                { "key": "search", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Admin Global Delete Document",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/documents/:id",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "documents", ":id"],
              "variable": [
                { "key": "id", "value": "your_document_id_here" }
              ]
            }
          }
        },
        {
          "name": "Trigger System Global Reindex",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/reindex",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "reindex"]
            }
          }
        },
        {
          "name": "Admin Inject Document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/admin/documents/upload",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "documents", "upload"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001/api", "type": "string" },
    { "key": "token", "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...", "type": "string" }
  ]
}
